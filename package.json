{
  "name": "sprite-dsl-tools",
  "version": "0.1.0",
  "description": "Mindustry Sprite DSL - pixel graphics generator",
  "type": "module",
  "bin": {
    "sprite-dsl": "./dist/cli/index.js"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "prebuild": "npm run clean",
    "build": "tsc && node build/build-web.js",
    "build:cli": "npm run clean && tsc",
    "build:web": "npm run clean && tsc && node build/build-web.js",
    "web": "npm run build:web && npx serve dist/web -l 3000",
    "cli": "node dist/cli/index.js",
    "test": "npx tsx tests/1001-dsl-to-txt/1001DslToTxt.ts",
    "dev": "npm run web"
  },
  "dependencies": {
    "pngjs": "^7.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/pngjs": "^6.0.0",
    "typescript": "^5.4.0",
    "serve": "^14.2.0"
  }
}
