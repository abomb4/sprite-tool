{
  "name": "sprite-dsl-tools",
  "version": "0.1.0",
  "description": "Mindustry Sprite DSL - pixel graphics generator",
  "type": "module",
  "bin": {
    "sprite-dsl": "./dist/cli/index.js"
  },
  "scripts": {
    "clean": "del /f /s /q dist 2>nul",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "build:cli": "npm run clean && tsc -p tsconfig.cli.json",
    "cli": "node dist/cli/index.js",
    "test": "npx tsx tests/1001-dsl-to-txt/1001DslToTxt.ts",
    "typecheck": "tsc --noEmit -p tsconfig.cli.json"
  },
  "dependencies": {
    "pngjs": "^7.0.0"
  },
  "devDependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/language": "^6.12.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.1",
    "@types/node": "^20.0.0",
    "@types/pngjs": "^6.0.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "codemirror": "^6.0.2",
    "esbuild": "^0.28.1",
    "serve": "^14.2.0",
    "typescript": "^5.4.0",
    "vite": "^8.0.0",
    "vue": "^3.5.38"
  }
}
