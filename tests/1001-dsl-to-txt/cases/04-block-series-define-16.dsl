dsl 1
size 16 16
template block

// =====================================================
// 调色板：6 个颜色，以数字为主题
// 1 2 3 4 5 6 从暗到亮
// =====================================================
palette {
  1 #663300
  2 #996600
  3 #cc9933
  4 #ffcc66
  5 #ffee99
  6 #ffffcc
}

// =====================================================
// 色阶系列：3 组
// 1↔6：最深↔最浅
// 2↔5：深↔浅
// 3↔4：中深↔中浅
// block 垂直镜像时色阶反转：
//   左上颜色 1 → 右下颜色 6
//   左上颜色 2 → 右下颜色 5
//   左上颜色 3 → 右下颜色 4
// =====================================================
series 1 6
series 2 5
series 3 4

// =====================================================
// 定义可复用图形 "corner"
// 在 define 块内，坐标相对图形自身的包围盒
// 这是一个 L 形拐角图案
// =====================================================
define corner {
  // L 形：大的竖条 + 小的横条
  // 包围盒：(0,0)-(3,3)，4×4
  rect 0,0 0,3 0 1   // 竖线，颜色1（最深）
  rect 1,0 3,0 0 2   // 横线，颜色2（深）
}

// =====================================================
// 定义可复用图形 "dot"
// 一个小圆点（用填充矩形模拟）
// =====================================================
define dot {
  // 包围盒：(0,0)-(2,2)，3×3
  rect 0,0 2,2 0 3   // 实心方块，颜色3
}

// =====================================================
// 测试 1: 直接绘制一些形状
// 用颜色验证 series 反转效果
// =====================================================

// 沿左上边缘画3个色块（验证 series）
// (0,0)-(3,3) 颜色1 → 右下应变为颜色6
rect 0,0 3,3 0 1

// (4,0)-(7,3) 颜色5 → 右下应变为颜色2
rect 4,0 7,3 0 5

// (0,4)-(3,5) 颜色6 → 右下应变为颜色1
rect 0,4 3,5 0 6

// =====================================================
// 测试 2: 使用 define 图形
// use <name> [transforms] <x>,<y>
// =====================================================

// 在 (0,7) 放置 corner → 包围盒4×4，放在左上三角底部
// (0,7+0)=(0,7) 到 (0+3,7+3)=(3,10) — 但 3+10=13<16 ✓, y<8? No!
// 10 ≥ 8 → 超出绘制区域！部分会被裁剪
// 改用 (0,5)：5<8 ✓, 3+5=8<16 ✓ 5+3=8=8 — 3+8=11<16 ✓
// 用 (4,2)：4+2=6<16 ✓, 4+3=7<16 ✓, y=2<8 ✓, y+3=5<8 ✓
// 完美！
use corner 4,2

// =====================================================
// 测试 3: 带变换的 use
// dot 放在 (9,2) — 9+2=11<16 ✓, 2+2=4<8 ✓
// 测试 r90 旋转：dot (0,0)-(2,2) 绕中心旋转90度
// =====================================================
// 不旋转
use dot 9,1

// =====================================================
// 测试 4: 再来一些 rect，覆盖不同位置
// 沿着斜边绘制细条
// =====================================================
// (8,5)-(10,5)：8+5=13<16 ✓, 10+5=15<16 ✓, y=5<8 ✓
// 颜色4 → 右下变为颜色3（series 3↔4）
rect 8,5 10,5 0 4

// (11,2)-(13,3)：11+2=13<16 ✓, 13+3=16 — 不行！
// 用 (11,2)-(12,3)：11+2=13<16 ✓, 12+3=15<16 ✓
// 颜色2 → 右下变为颜色5
rect 11,2 12,3 0 2