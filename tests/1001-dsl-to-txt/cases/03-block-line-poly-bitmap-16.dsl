dsl 1
size 16 16
template block

// =====================================================
// 调色板：4 个颜色
// 1#ff0000  纯红
// 2#00ff00  纯绿
// 3#0000ff  纯蓝
// 4#ffff00  纯黄
// =====================================================
palette {
  1 #ff0000
  2 #00ff00
  3 #0000ff
  4 #ffff00
}

// =====================================================
// 色阶系列：1↔4 和 2↔3
// block 模板的垂直镜像会反转颜色
// 验证：左上角的颜色 1 在右下角变为 4
//       左上角的颜色 2 在右下角变为 3
// =====================================================
series 1 4
series 2 3

// =====================================================
// 测试 1: 线段（细线）
// 从 (0,0) 到 (7,7) 的对角线
// 0+0=0<16 ✓, 7+7=14<16 ✓, y=7<8 ✓
// radius=0 → 1 像素宽的线
// 颜色 1 → 红色
// 在右上镜像：颜色不变
// 在左下镜像：颜色反转 → 4（黄色）
// =====================================================
line 0,0 7,7 0 1

// =====================================================
// 测试 2: 线段（粗线）
// 从 (0,5) 到 (10,5) 的水平粗线
// 0+5=5<16 ✓, 10+5=15<16 ✓, y=5<8 ✓
// radius=2 → 向两侧各扩展 2 像素，总宽度 5 像素
// 颜色 2 → 绿色
// 注意：线段的上下边缘可能超出绘制区域，会自动裁剪
// =====================================================
line 0,5 10,5 2 2

// =====================================================
// 测试 3: 多边形（三角形）
// 顶点： (1,2)-(5,1)-(3,4)
// 1+2=3<16 ✓, 5+1=6<16 ✓, 3+4=7<16 ✓
// 填充一个三角形区域
// 颜色 3 → 蓝色
// =====================================================
poly 1,2 5,1 3,4 3

// =====================================================
// 测试 4: 多边形（四边形）
// 顶点： (7,3)-(11,3)-(10,6)-(8,6)
// 7+3=10<16 ✓, 11+3=14<16 ✓, 10+6=16 超了...
// 用 (7,3)-(10,3)-(9,5)-(7,5)：7+3=10<16 ✓, 9+5=14<16 ✓
// 填充一个扁四边形
// 颜色 4 → 黄色
// =====================================================
poly 7,3 10,3 9,5 7,5 4

// =====================================================
// 测试 5: Bitmap 像素网格
// 放置于 (0,0)，一个 4×3 的像素图
// "0"=透明，"1"~"4"=调色板颜色
// ................
// 11    → 红红
// 1 22  → 红+绿绿
// 1 334 → 红+蓝蓝黄
// ................
// 验证：series 反转后右下角变为 4（黄）、3（蓝）、2（绿）、1（红）
// =====================================================
bitmap 0,0 {
 1100
 1022
 1334
}