dsl 1
size 16 16
template block

// =====================================================
// 调色板：5 个颜色，从暗到亮
// =====================================================
// 1#2a2a2a  深灰（最暗）
// 2#4a4a4a  中灰
// 3#6a6a6a  浅灰
// 4#8a8a8a  亮灰
// 5#aaaaaa  最亮（仅用于对比）
// =====================================================
palette {
  1 #2a2a2a
  2 #4a4a4a
  3 #6a6a6a
  4 #8a8a8a
  5 #aaaaaa
}

// =====================================================
// 测试 1: 无切角矩形（原始行为）
// 在左上角绘制一个 7x7 的矩形，无切角
// 绘制区域：左上角三角形 (0,0)-(15,0)-(0,7)
// 矩形 (0,0)-(6,6)：完全在可绘制区域内
// 预期：矩形区域填实，没有切角
// =====================================================
// rect 无切角，实心方块
rect 0,0 6,6 0 1

// =====================================================
// 测试 2: 带切角的矩形
// 切角边长=3，坐标 (3,0)-(10,7)
// 先保证在可绘制区域内：x+y<16 → 10+7=17 超了！
// 改用 (3,0)-(10,6)：10+6=16，也不行（x+y<16 不含等号）
// 改用 (3,0)-(9,6)：9+6=15<16 ✓，y=6<8 ✓
// =====================================================
// 矩形 (3,0)-(9,6) 切角 3，四个角各切掉一个等腰直角三角形
// 左上角：(3,0)(3,3)(6,0) 区域被切掉
// 右上角：(9,0)(9,3)(6,0) 区域被切掉
// 左下角：(3,6)(3,3)(6,6) 区域被切掉
// 右下角：(9,6)(9,3)(6,6) 区域被切掉
// 剩余部分呈八边形
rect 3,0 9,6 3 2

// =====================================================
// 测试 3: 大切角矩形（切掉大部分）
// 矩形 (1,1)-(7,7) 切角 5
// 1+1=2<16 ✓, 7+7=14<16 ✓, y=7<8 ✓
// 切角 5：四个角各切掉曼哈顿距离<5的三角形
// 最终只剩中央一个很小的菱形区域
// =====================================================
rect 1,1 7,7 5 3

// =====================================================
// 测试 4: 沿斜边的小矩形
// 矩形 (8,2)-(12,4)：8+2=10<16 ✓, 12+4=16 — 等于也不行！
// 用 (8,2)-(11,4)：11+4=15<16 ✓
// 切角 2，颜色 4
// =====================================================
rect 8,2 11,4 2 4

// =====================================================
// 测试 5: 1像素宽矩形（细线效果）
// 矩形 (0,0)-(0,7)：0+7=7<16 ✓ 但 y=7<8 ✓
// 注意：只有 x=0 这一列，宽1像素
// =====================================================
rect 0,0 0,7 0 5